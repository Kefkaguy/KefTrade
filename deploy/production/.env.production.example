POSTGRES_USER=keftrade
POSTGRES_PASSWORD=replace_with_a_strong_database_password
POSTGRES_DB=keftrade

DATABASE_URL=postgresql://keftrade:replace_with_a_strong_database_password@postgres:5432/keftrade

KEFTRADE_ENV=production
KEFTRADE_WORKER_ID=campaign-worker-1
KEFTRADE_WORKER_POLL_SECONDS=5
KEFTRADE_MAX_CAMPAIGN_WORKERS=8
KEFTRADE_CAMPAIGN_WORKER_HEARTBEAT_SECONDS=10
KEFTRADE_CAMPAIGN_WORKER_STALE_SECONDS=45

# Comma-separated frontend origins allowed by FastAPI CORS.
# Add the final Vercel production URL and any preview URL you trust.
CORS_ORIGINS=https://your-vercel-project.vercel.app,http://localhost:3000,http://127.0.0.1:3000

BINANCE_BASE_URL=https://api.binance.us

# LLM provider configuration. Leave unused providers blank. 
LLM_PROVIDER=groq
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
RESEARCH_COPILOT_MODEL=

# Market data / paper-simulation provider configuration.
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_DATA_BASE_URL=https://data.alpaca.markets
ALPACA_TRADING_BASE_URL=https://paper-api.alpaca.markets
ALPACA_INTRADAY_MAX_LOOKBACK_DAYS=1825
PAPER_SCAN_MAX_CANDLE_AGE_HOURS=96
